{
  "packages": {
    "packages/lib": {
      "component": "lib",
      "release-type": "node"
    },
    "packages/dashboard": {
      "component": "dashboard",
      "release-type": "node"
    },
    ".": {
      "component": "server",
      "release-type": "rust"
    },
    "charts/feedback-fusion": {
      "component": "helm-feedback-fusion",
      "release-type": "helm"
    }
  },
  "plugins": [
    "cargo-workspace",
    "node-workspace"
  ],
  "commit-search-depth": 5,
  "sequential-calls": true
}
